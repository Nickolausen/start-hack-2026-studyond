{
  "compilerOptions": {
    "lib": ["es6", "dom"],
    "target": "es6",
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "shared/*": ["../shared/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
